{
  "name": "@corpollc/qntm",
  "version": "0.4.2",
  "qntmSpecVersion": "QSP-v1.1",
  "description": "QSP v1.1 protocol library \u2014 identity, invites, encrypted messaging, and threshold gate signing",
  "type": "module",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/corpollc/qntm/tree/main/client",
  "bugs": {
    "url": "https://github.com/corpollc/qntm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/corpollc/qntm.git",
    "directory": "client"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "qntm",
    "qsp",
    "messaging",
    "encryption",
    "ed25519"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cross": "vitest run --config vitest.cross.config.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "@noble/ciphers": "^1.2.1",
    "@noble/curves": "^1.8.1",
    "cbor-x": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
