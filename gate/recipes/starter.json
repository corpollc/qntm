      "risk_tier": "read",
      "threshold": 1,
      "content_type": "application/json",
      "body_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to translate to leet speak"
          }
        },
        "required": [
          "text"
        ]
      },
      "body_example": {
        "text": "Hello World"
      }
    },
