      "target_url": "https://opentdb.com/api.php?amount=1",
      "risk_tier": "read",
      "threshold": 1,
      "content_type": "application/json"
    },
    "dogs.random": {
      "name": "dogs.random",
      "description": "Get a random dog image URL (JSON with image link)",
      "service": "dogs",
      "verb": "GET",
      "endpoint": "/breeds/image/random",
      "target_url": "https://dog.ceo/api/breeds/image/random",
      "risk_tier": "read",
      "threshold": 1,
      "content_type": "application/json"
    },
    "dogs.breed": {
