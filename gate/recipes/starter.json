      "description": "Get a random image of a specific dog breed",
      "service": "dogs",
      "verb": "GET",
      "endpoint": "/breed/{breed}/images/random",
      "target_url": "https://dog.ceo/api/breed/{breed}/images/random",
      "risk_tier": "read",
