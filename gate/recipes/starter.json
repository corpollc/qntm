      "service": "hackernews",
      "verb": "GET",
      "endpoint": "/item/{id}.json",
      "target_url": "https://hacker-news.firebaseio.com/v0/item/{id}.json",
      "risk_tier": "read",
      "threshold": 1,
      "content_type": "application/json",
      "path_params": [
        {"name": "id", "description": "Hacker News item ID", "required": true, "type": "string"}
      ]
    },
    "httpbin.echo": {
      "name": "httpbin.echo",
      "description": "Echo POST body and headers back (verifies credential injection)",
      "service": "httpbin",
      "verb": "POST",
      "endpoint": "/post",
      "target_url": "https://httpbin.org/post",
      "risk_tier": "read",
      "threshold": 2,
      "content_type": "application/json",
      "body_schema": {"type": "object", "properties": {"data": {"type": "string", "description": "Arbitrary data to echo back"}}},
      "body_example": {"data": "hello"}
    },
    "httpbin.headers": {
      "name": "httpbin.headers",
      "description": "Return request headers (shows injected auth)",
      "service": "httpbin",
      "verb": "GET",
      "endpoint": "/headers",
      "target_url": "https://httpbin.org/headers",
      "risk_tier": "read",
      "threshold": 1,
      "content_type": "application/json"
    },
    "jokes.dad": {
