      "target_url": "https://api.openai.com/v1/chat/completions",
      "risk_tier": "write",
      "threshold": 2,
      "content_type": "application/json",
      "body_schema": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "model",
          "messages"
        ]
      },
      "body_example": {
        "model": "gpt-4o-mini",
        "messages": [
          {
            "role": "user",
            "content": "Say hello in exactly 5 words"
          }
        ]
      }
    },
    "anthropic.messages": {
      "name": "anthropic.messages",
      "description": "Create a message with Anthropic Claude",
      "service": "anthropic",
      "verb": "POST",
      "endpoint": "/v1/messages",
      "target_url": "https://api.anthropic.com/v1/messages",
      "risk_tier": "write",
      "threshold": 2,
      "content_type": "application/json",
      "body_schema": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string"
          },
          "max_tokens": {
            "type": "integer"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "model",
          "max_tokens",
          "messages"
        ]
      },
      "body_example": {
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 256,
        "messages": [
          {
            "role": "user",
            "content": "Say hello in exactly 5 words"
          }
        ]
      }
    },
